# 로컬 개발용 — 이 파일을 .env로 복사해서 사용하세요
# 서버 배포 시에는 provision 과정에서 자동으로 설정됩니다
#
# ※ 모든 env 는 app/config.py 한 곳에서 읽습니다. 새 변수는 거기에 추가하세요.

PORT=8000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydb
DB_USER=myuser
DB_PASS=mypassword

# ── 프론트에 내려줄 공개 키 (GET /config) ─────────────────────
# 서버 배포 시에는 선생님 공유 키(config/maps.env)가 자동 주입됩니다.
# 로컬에서 테스트할 때만 아래 주석을 풀고 값을 채우세요.
# NAVER_MAPS_CLIENT_ID=
# KAKAO_MAPS_APP_KEY=
